{
  "cmake.configureOnOpen": true,
  "cmake.buildDirectory": "${workspaceFolder}/build_mingw",
  "cmake.configureSettings": {
    "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
  },
  "C_Cpp.default.compilerPath": "C:/msys64/ucrt64/bin/gcc.exe",
  "C_Cpp.default.cStandard": "c11",
  "C_Cpp.default.intelliSenseMode": "windows-gcc-x64",
  "C_Cpp.default.compileCommands": "${workspaceFolder}/compile_commands.json",
  "C_Cpp.default.defines": [
    "projCOVERAGE_TEST=0"
  ],
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/include",
    "${workspaceFolder}/FreeRTOS-KernelV11.3.0/include",
    "${workspaceFolder}/FreeRTOS-KernelV11.3.0/portable/MSVC-MingW",
    "C:/msys64/ucrt64/include"
  ],
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.autocomplete": "disabled",
  "C_Cpp.errorSquiggles": "disabled",
  "clangd.enable": true,
  "clangd.checkUpdates": false,
  "clangd.onConfigChanged": "restart",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}",
    "--query-driver=C:/msys64/ucrt64/bin/*",
    "--header-insertion=never"
  ],
  "files.associations": {
    "FreeRTOS.h": "c",
    "event_groups.h": "c",
    "queue.h": "c",
    "semphr.h": "c",
    "task.h": "c",
    "timers.h": "c"
  }
}
